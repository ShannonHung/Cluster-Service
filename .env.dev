APP_ENV=dev
APP_NAME="Cluster Service"
APP_VERSION="0.1.0"
DEBUG=true
LOG_LEVEL=DEBUG

# JWT
SECRET_KEY=dev-secret-key-change-in-production-minimum-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Users store
USERS_JSON_PATH=data/users.json

# Deploy Service
DEPLOY_SERVICE_URL=http://localhost:8001
DEPLOY_SERVICE_TOKEN=
DEPLOY_SERVICE_USERNAME=cluster_proxy
DEPLOY_SERVICE_PASSWORD=cluster_proxy_dev_pw